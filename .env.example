# Anthropic API Key (required for agent loop)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Coinbase Developer Platform (CDP) credentials (required for live trading)
CDP_API_KEY_ID=your_cdp_api_key_id_here
CDP_API_KEY_SECRET=-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----\n
CDP_WALLET_SECRET=your_base64_encoded_der_ec_key_here

# Network: base-mainnet for production, base-sepolia for testnet
NETWORK_ID=base-mainnet
